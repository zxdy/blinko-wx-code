# 测试环境配置示例
# 复制此文件为 .env.test 并填入真实值

# ============================================
# Blinko 配置（必需，用于真实 API 测试）
# ============================================
# Blinko API 地址（笔记创建/更新接口）
BLINKO_API_URL=http://your-blinko-server/api/v1/note/upsert

# Blinko API Token（从 Blinko 后台获取）
BLINKO_API_TOKEN=your_blinko_api_token_here

# ============================================
# 企业微信配置（可选，用于完整 E2E 测试）
# ============================================
WECOM_CORP_ID=your_corp_id_here
WECOM_CORP_SECRET=your_corp_secret_here
WECOM_TOKEN=your_token_here
WECOM_AES_KEY=your_aes_key_here

# ============================================
# 服务器配置（测试使用默认值）
# ============================================
HOST=0.0.0.0
PORT=5001

# ============================================
# 回调通知 URL（可选）
# ============================================
# CALLBACK_URL=https://your-callback-server/notify

# ============================================
# 缓存配置
# ============================================
CACHE_EXPIRE_SECONDS=600

# ============================================
# 测试专用配置
# ============================================

# 测试用户 ID（用于隔离测试数据）
TEST_USER_ID=test_user_001

# 测试图片 URL（使用可访问的图片 URL）
# 推荐使用 picsum.photos 随机图片服务
TEST_IMAGE_URL=https://picsum.photos/200/300

# 是否跳过真实服务测试
# true  - 跳过所有需要真实服务的测试（无配置时使用）
# false - 使用真实 Blinko API 进行测试（需要配置 BLINKO_API_URL 和 BLINKO_API_TOKEN）
SKIP_REAL_SERVICE_TESTS=false

# 待更新笔记缓存过期时间（秒）
PENDING_NOTE_EXPIRE_SECONDS=120
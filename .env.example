# 企业微信配置
WECOM_CORP_ID=your_corp_id_here
WECOM_CORP_SECRET=your_corp_secret_here
WECOM_TOKEN=your_token_here
WECOM_AES_KEY=your_aes_key_here
WECOM_AGENT_ID=your_agent_id_here

# Blinko配置
BLINKO_API_URL=http://your-blinko-server/api/v1/note/upsert
BLINKO_API_TOKEN=your_blinko_api_token_here

# 服务器配置
HOST=0.0.0.0
PORT=5001

# 回调通知URL(可选)
# CALLBACK_URL=http://your-callback-server/notify

# 缓存过期时间(秒,默认600)
CACHE_EXPIRE_SECONDS=600
